<UserControl
    x:Class="VRCGroupTools.Views.InviteStatsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="📊 Invite Statistics"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="White"/>
            <TextBlock Text="Tracks how effective each inviter is over time"
                       FontSize="13"
                       Foreground="#888"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="#1E1E1E"
                CornerRadius="10"
                Padding="12">

            <DataGrid ItemsSource="{Binding Stats}"
          AutoGenerateColumns="False"
          HeadersVisibility="Column"
          GridLinesVisibility="None"
          RowBackground="#1E1E1E"
          AlternatingRowBackground="#252526"
          Foreground="White"
          CanUserAddRows="False"
          CanUserResizeRows="False"
          CanUserSortColumns="True"
          BorderThickness="0"
          Style="{StaticResource MaterialDesignDataGrid}">

                <!-- ✅ ROW STYLE GOES HERE -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Cursor" Value="Hand"/>
                        <EventSetter Event="MouseDoubleClick"
                         Handler="{Binding DataContext.ShowInviterHistoryCommand,
                                   RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Inviter"
                            Binding="{Binding InviterName}"
                            Width="2*"/>

                    <DataGridTextColumn Header="Sent"
                            Binding="{Binding Sent}"
                            Width="*"/>

                    <DataGridTextColumn Header="Accepted"
                            Binding="{Binding Accepted}"
                            Width="*"/>

                    <DataGridTextColumn Header="Expired"
                            Binding="{Binding Expired}"
                            Width="*"/>

                    <DataGridTemplateColumn Header="Acceptance Rate"
                                Width="3*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <ProgressBar Value="{Binding AcceptanceRate}"
                                     Maximum="1"
                                     Height="8"
                                     Foreground="#7C4DFF"
                                     Background="#333"/>
                                    <TextBlock Text="{Binding AcceptanceRate, StringFormat={}{0:P0}}"
                                   FontSize="11"
                                   Foreground="#AAA"
                                   HorizontalAlignment="Right"
                                   Margin="0,10,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>  