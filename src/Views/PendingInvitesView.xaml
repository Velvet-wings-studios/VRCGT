<UserControl
    x:Class="VRCGroupTools.Views.PendingInvitesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="⏳ Pending Invites"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="White"/>
            <TextBlock Text="Invites that have been sent but not yet accepted"
                       Foreground="#888"
                       FontSize="13"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <!-- List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Pending}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1E1E1E"
                                CornerRadius="10"
                                Padding="12"
                                Margin="0,0,0,12">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Avatar -->
                                <Border Width="48"
                                        Height="48"
                                        CornerRadius="24"
                                        Grid.Column="0"
                                        ClipToBounds="True">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding TargetAvatarUrl}"
                                                    Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>

                                <!-- Info -->
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding TargetName}"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               FontSize="14"/>

                                    <TextBlock Text="{Binding InviterName, StringFormat=Invited by {0}}"
                                               Foreground="#AAA"
                                               FontSize="12"
                                               Margin="0,2,0,0"/>

                                    <TextBlock Text="{Binding PendingFor, StringFormat=Pending for {0:g}}"
                                               Foreground="#888"
                                               FontSize="11"
                                               Margin="0,6,0,0"/>
                                </StackPanel>

                                <!-- Expiry -->
                                <StackPanel Grid.Column="2"
                                            HorizontalAlignment="Right">
                                    <TextBlock Text="Expires in"
                                               Foreground="#AAA"
                                               FontSize="11"
                                               HorizontalAlignment="Right"/>

                                    <TextBlock Text="{Binding ExpiresIn, StringFormat={}{0:d\\.hh\\:mm}}"
                                               FontWeight="Bold"
                                               Foreground="#FF9800"
                                               FontSize="13"
                                               HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
    
      